{
    "mcpServers": {
        "jira-mcp": {
            "command": "node",
            "args": [
                "-e",
                "await import(require('path').resolve(__dirname || '.','build','index.js'))"
            ],
            "env": {
                "JIRA_API_TOKEN": "",
                "JIRA_BASE_URL": "",
                "JIRA_USER_EMAIL": "",
                "JIRA_TYPE": "cloud",
                "JIRA_AUTH_TYPE": "basic"
            },
            "disabled": false,
            "autoApprove": []
        }
    }
}